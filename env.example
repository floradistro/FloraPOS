# Flora POS Environment Variables
# Copy this file to .env.local and fill in your actual values

# WordPress/WooCommerce API Configuration (Working Test Credentials)
NEXT_PUBLIC_WORDPRESS_URL=https://api.floradistro.com
NEXT_PUBLIC_WC_CONSUMER_KEY=ck_bb8e5fe3d405e6ed6b8c079c93002d7d8b23a7d5
NEXT_PUBLIC_WC_CONSUMER_SECRET=cs_38194e74c7ddc5d72b6c32c70485728e7e529678

# App Configuration
NEXT_PUBLIC_APP_URL=https://your-vercel-app.vercel.app

# Server-side only environment variables (don't prefix with NEXT_PUBLIC_)
WC_CONSUMER_KEY=ck_your_consumer_key_here
WC_CONSUMER_SECRET=cs_your_consumer_secret_here
FLORA_CONSUMER_KEY=ck_your_consumer_key_here
FLORA_CONSUMER_SECRET=cs_your_consumer_secret_here

# JWT Secret for authentication (generate a secure random string)
JWT_SECRET=your_jwt_secret_here

# Optional: Flora API specific
NEXT_PUBLIC_FLORA_API_URL=https://api.floradistro.com

# Optional: Storage encryption key
NEXT_PUBLIC_STORAGE_KEY=your_storage_encryption_key

# Optional: Redis for rate limiting (if using)
REDIS_URL=redis://your-redis-url

# Optional: Logging endpoint
LOGGING_ENDPOINT=https://your-logging-service.com/api/logs